# ============================================================
# Oren Studio AI — Environment Variables (example)
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- Core ----
ENV=development
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
STUDIO_API_KEY=change-me   # simple single-user API key auth (see docs/decisions.md ADR-006)

# ---- Postgres (source of truth) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=oren_studio
POSTGRES_USER=oren_studio
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://oren_studio:change-me@localhost:5432/oren_studio

# ---- Redis (event bus / cache) ----
REDIS_URL=redis://localhost:6379/0

# ---- Qdrant (vector index) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# QDRANT_PATH=       # optional: local/embedded-mode override (no server) for
                      # dev/test convenience — see packages/memory/memory/store.py.
                      # When set, agents/knowledge_agent and apps/api's knowledge
                      # search route use this instead of QDRANT_URL.

# ---- S3-compatible storage (MinIO locally) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=oren-studio-assets
S3_REGION=us-east-1

# ---- LLM Routing (LiteLLM) — see docs/open-source-landscape.md ----
LITELLM_MASTER_KEY=change-me
OREN_STUDIO_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# OpenRouter kept only as an optional secondary/failover provider behind LiteLLM
OPENROUTER_API_KEY=

# ---- Embeddings (LiteLLM -> Voyage AI, Knowledge Agent — docs/agents.md) ----
OREN_STUDIO_EMBEDDING_MODEL=voyage/voyage-3-lite
VOYAGE_API_KEY=

# ---- Search / Crawling ----
TAVILY_API_KEY=
SEARXNG_URL=http://localhost:8080
FIRECRAWL_API_URL=http://localhost:3002   # self-hosted

# ---- STT / OCR (self-hosted, no keys needed by default) ----
WHISPER_MODEL=ivrit-ai/faster-whisper-v2-d4

# ---- Voice (commercial default — see docs/decisions.md ADR-004) ----
ELEVENLABS_API_KEY=

# ---- Publishing (filled in once Phase 0.5 app reviews are approved) ----
POSTIZ_API_URL=
POSTIZ_API_KEY=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
